# General
LIBRARY_DIR=D:\MusicVideos\Library
ARCHIVE_DIR=D:\MusicVideos\Archive
PREVIEW_CACHE_DIR=D:\MusicVideos\Previews
LOG_DIR=./logs

# Tools
FFMPEG_PATH=auto
FFPROBE_PATH=auto
YTDLP_PATH=auto

# Audio Normalization
NORMALIZATION_TARGET_LUFS=-14.0
NORMALIZATION_LRA=7.0
NORMALIZATION_TP=-1.5

# Database
DATABASE_URL=sqlite:///./playarr.db

# Redis
REDIS_URL=redis://localhost:6379/0

# MusicBrainz
MUSICBRAINZ_APP=Playarr
MUSICBRAINZ_VERSION=1.0.0
MUSICBRAINZ_CONTACT=user@example.com

# AI Summaries (optional)
AI_PROVIDER=none
GEMINI_API_KEY=
OPENAI_API_KEY=

# Preview
PREVIEW_DURATION_SEC=8
PREVIEW_START_PERCENT=30

# Server
HOST=0.0.0.0
PORT=8000
