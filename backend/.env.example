# =============================================================================
# Playarr Configuration
# =============================================================================
# Copy this file to .env and adjust values for your system.
# All paths should use your OS's native format (backslashes on Windows, etc.).
# =============================================================================

# ─── Directories (optional) ──────────────────────────────────────────────────
# All directories default to sensible locations next to the executable/project.
# Override only if you want to store data elsewhere.

# Directory where your organised music video library is stored.
LIBRARY_DIR=/path/to/your/library

# Directory for archived/replaced video files (quality upgrades move old files here).
ARCHIVE_DIR=/path/to/your/archive

# Directory for cached hover-preview clips.
PREVIEW_CACHE_DIR=/path/to/your/previews

# Directory for cached artwork and entity assets (posters, fanart, thumbnails).
# ASSET_CACHE_DIR=/path/to/your/asset-cache

# Directory for application logs.
LOG_DIR=./logs

# ─── Tools ───────────────────────────────────────────────────────────────────
# Set to "auto" to search PATH, or provide an absolute path to the binary.

FFMPEG_PATH=auto
FFPROBE_PATH=auto
YTDLP_PATH=auto

# ─── Audio Normalization ─────────────────────────────────────────────────────

# Target integrated loudness (LUFS). -14 = Spotify/Apple Music standard.
NORMALIZATION_TARGET_LUFS=-14.0

# Loudness Range (LU). Lower = more consistent volume.
NORMALIZATION_LRA=7.0

# True Peak maximum (dBTP). -1.0 = standard for streaming.
NORMALIZATION_TP=-1.5

# ─── Database ────────────────────────────────────────────────────────────────

# SQLite (default) or PostgreSQL connection string.
DATABASE_URL=sqlite:///./playarr.db

# ─── Redis (optional) ────────────────────────────────────────────────────────
# Optional. When Redis is available, Celery handles background tasks.
# Without Redis, Playarr falls back to an in-process thread worker.

REDIS_URL=redis://localhost:6379/0

# ─── MusicBrainz ─────────────────────────────────────────────────────────────
# MusicBrainz requires a user-agent with app name, version, and contact.

MUSICBRAINZ_APP=Playarr
MUSICBRAINZ_VERSION=1.0.0
MUSICBRAINZ_CONTACT=your-email@example.com

# ─── AI Providers (optional) ─────────────────────────────────────────────────
# Set AI_PROVIDER to one of: none, openai, gemini, claude, local
# Then provide the corresponding API key below.

AI_PROVIDER=none

# OpenAI (GPT-4o, GPT-4.1, etc.)
OPENAI_API_KEY=

# Google Gemini (Gemini 2.0/2.5)
GEMINI_API_KEY=

# Anthropic Claude (Sonnet 4, Opus 4, etc.)
CLAUDE_API_KEY=

# Local LLM via Ollama (no API key needed)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3

# ─── Preview Generation ──────────────────────────────────────────────────────

# Duration of hover-preview clips in seconds.
PREVIEW_DURATION_SEC=8

# Where in the video to start the preview (percentage of total duration).
PREVIEW_START_PERCENT=30

# ─── Server ──────────────────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=6969
